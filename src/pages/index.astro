---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'UpgradR — Passez au niveau supérieur',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Prendre contact',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'Voir les services', href: '#services' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=2070&q=80', alt: 'UpgradR — Automatisation entreprise' }}
  >
    <Fragment slot="title">
      Passez au <span class="text-accent dark:text-white">niveau supérieur.</span>
    </Fragment>

    <Fragment slot="subtitle">
      UpgradR audite vos processus et automatise vos tâches répétitives.
      Moins de friction, plus de performance — sans recruter.
    </Fragment>
  </Hero>

  <!-- Services -->
  <Features
    id="services"
    tagline="Services"
    title="Ce qu'on fait pour vous"
    subtitle="On intervient là où vous perdez du temps et de l'argent sans le savoir."
    items={[
      {
        title: 'Audit processus',
        description: 'On cartographie vos flux de travail pour identifier les goulots d\'étranglement, les tâches manuelles inutiles et les outils mal exploités.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Automatisation sur mesure',
        description: 'Scripts, webhooks, no-code ou code — on automatise ce qui vous prend du temps : relances, reporting, synchronisation de données, etc.',
        icon: 'tabler:robot',
      },
      {
        title: 'Intégration IA',
        description: 'Chatbots internes, traitement de documents, génération de contenus, extraction de données — on intègre l\'IA là où elle crée de la valeur réelle.',
        icon: 'tabler:brain',
      },
      {
        title: 'Tableaux de bord & reporting',
        description: 'Vos données éparpillées dans 10 outils différents ? On centralise et on automatise vos rapports pour que vous pilotiez en temps réel.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Connexion d\'outils (CRM, ERP, etc.)',
        description: 'Zapier, Make, API custom — on connecte vos outils entre eux pour supprimer les copier-coller et les erreurs humaines.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Formation & accompagnement',
        description: 'On ne disparaît pas après la livraison. On forme vos équipes et on reste disponibles pour itérer sur ce qu\'on a mis en place.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Process -->
  <Steps
    id="process"
    title="Comment ça marche"
    items={[
      {
        title: 'Étape 1 : <span class="font-medium">Audit gratuit</span>',
        description: 'Un appel de 30 min pour comprendre votre situation, vos outils et vos points de douleur. On vous dit franchement si on peut vous aider.',
        icon: 'tabler:phone',
      },
      {
        title: 'Étape 2 : <span class="font-medium">Proposition sur mesure</span>',
        description: 'On vous présente un plan d\'action clair avec les automations prioritaires, les gains estimés et le budget.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Étape 3 : <span class="font-medium">Déploiement</span>',
        description: 'On met en place les solutions, on teste, on forme vos équipes. Délai typique : 2 à 4 semaines selon la complexité.',
        icon: 'tabler:rocket',
      },
      {
        title: 'C\'est parti.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=2070&q=80',
      alt: 'Process UpgradR',
    }}
  />

  <!-- FAQ -->
  <FAQs
    id="faq"
    title="Questions fréquentes"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'On est une petite entreprise, c\'est fait pour nous ?',
        description: 'Oui. On travaille avec des TPE et PME de 5 à 200 personnes. Les petites structures ont souvent plus à gagner à automatiser, car chaque heure compte davantage.',
      },
      {
        title: 'On a déjà des outils en place, vous travaillez avec ?',
        description: 'Dans la majorité des cas, oui. On s\'adapte à votre stack existant (Google Workspace, Notion, Airtable, HubSpot, etc.) avant de recommander de nouveaux outils.',
      },
      {
        title: 'Combien ça coûte ?',
        description: 'Ça dépend du périmètre. L\'audit initial est gratuit. Ensuite, on propose un devis fixe par projet — pas de facturation à l\'heure qui dérape.',
      },
      {
        title: 'Et si ça ne fonctionne pas après ?',
        description: 'On garantit un suivi post-déploiement. Si une automation plante ou si le besoin évolue, on corrige sans facturation supplémentaire pendant la période de garantie.',
      },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Réserver un audit gratuit',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Prêt à gagner du temps ?
    </Fragment>

    <Fragment slot="subtitle">
      Un appel de 30 min suffit pour identifier vos premières pistes d'automatisation.
    </Fragment>
  </CallToAction>

</Layout>
