---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Note from '~/components/widgets/Note.astro';

const metadata = {
  title: 'UpgradR — Audit & Automatisation pour Entreprises',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Réserver un audit gratuit',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'Voir les services', href: '#services' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=2070&q=80', alt: 'UpgradR — Automatisation entreprise' }}
  >
    <Fragment slot="title">
      Passez au <span class="text-accent dark:text-white">niveau supérieur.</span>
    </Fragment>

    <Fragment slot="subtitle">
      UpgradR audite vos processus et automatise vos tâches répétitives.
      <strong>Moins de friction, plus de performance</strong> — sans recruter.
    </Fragment>
  </Hero>

  <!-- Accroche confiance -->
  <Note title="Audit gratuit :" description="30 minutes d'appel pour identifier vos premières pistes d'automatisation — sans engagement, sans jargon." />

  <!-- Services -->
  <Features
    id="services"
    tagline="Services"
    title="Ce qu'on fait pour vous"
    subtitle="On intervient là où vous perdez du temps et de l'argent sans le savoir."
    items={[
      {
        title: 'Audit processus',
        description: 'On cartographie vos flux de travail pour identifier les tâches manuelles inutiles, les goulots d\'étranglement et les outils mal exploités.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Automatisation sur mesure',
        description: 'Scripts, webhooks, no-code ou code — on automatise ce qui vous prend du temps : relances, reporting, synchronisation de données, facturation, etc.',
        icon: 'tabler:robot',
      },
      {
        title: 'Intégration IA',
        description: 'Chatbots internes, traitement de documents, génération de contenus, extraction de données — on intègre l\'IA là où elle crée de la valeur réelle.',
        icon: 'tabler:brain',
      },
      {
        title: 'Tableaux de bord & reporting',
        description: 'Vos données éparpillées dans 10 outils ? On centralise et on automatise vos rapports pour piloter en temps réel sans intervention manuelle.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Connexion d\'outils (CRM, ERP, etc.)',
        description: 'Zapier, Make, API custom — on connecte vos outils entre eux pour supprimer les saisies multiples et les erreurs humaines.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Formation & accompagnement',
        description: 'On ne disparaît pas après la livraison. On forme vos équipes et on reste disponibles pour itérer sur ce qu\'on a mis en place.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Process -->
  <Steps
    id="process"
    title="3 étapes pour automatiser votre entreprise"
    items={[
      {
        title: 'Étape 1 : <span class="font-medium">Audit gratuit (30 min)</span>',
        description: 'Un appel pour comprendre votre situation, vos outils et vos points de douleur. On vous dit franchement si on peut vous aider — et comment.',
        icon: 'tabler:phone',
      },
      {
        title: 'Étape 2 : <span class="font-medium">Proposition sur mesure</span>',
        description: 'Un plan d\'action clair avec les automations prioritaires, les gains estimés et un devis fixe. Pas de surprise.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Étape 3 : <span class="font-medium">Déploiement & formation</span>',
        description: 'On met en place les solutions, on teste, on forme vos équipes. Délai typique : 2 à 4 semaines.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Votre entreprise tourne seule.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=2070&q=80',
      alt: 'Process UpgradR',
    }}
  />

  <!-- FAQ -->
  <FAQs
    id="faq"
    title="Questions fréquentes"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'On est une petite entreprise, c\'est fait pour nous ?',
        description: 'Oui. On travaille avec des TPE et PME de 5 à 200 personnes. Les petites structures ont souvent plus à gagner à automatiser — chaque heure perdue compte davantage.',
      },
      {
        title: 'On a déjà des outils en place, vous travaillez avec ?',
        description: 'Dans la majorité des cas, oui. On s\'adapte à votre stack existant (Google Workspace, Notion, Airtable, HubSpot, Salesforce, etc.) avant de recommander quoi que ce soit.',
      },
      {
        title: 'Combien ça coûte ?',
        description: 'L\'audit initial est 100% gratuit. Ensuite, on propose un devis fixe par projet — pas de facturation à l\'heure. Vous savez ce que vous payez avant de vous engager.',
      },
      {
        title: 'Combien de temps ça prend ?',
        description: 'Entre 2 et 4 semaines selon la complexité. Certaines automations simples peuvent être livrées en moins d\'une semaine.',
      },
      {
        title: 'Et si ça ne fonctionne pas après la livraison ?',
        description: 'On garantit un suivi post-déploiement. Si une automation plante ou si le besoin évolue, on corrige sans facturation supplémentaire pendant la période de garantie.',
      },
    ]}
  />

  <!-- CTA final -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Réserver mon audit gratuit',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Combien vous coûte une heure de tâche manuelle par jour ?
    </Fragment>

    <Fragment slot="subtitle">
      Calculez ce que l'automatisation peut vous rapporter.<br/>
      L'audit est gratuit — la décision vous appartient.
    </Fragment>
  </CallToAction>

</Layout>
