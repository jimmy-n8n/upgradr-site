---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Note from '~/components/widgets/Note.astro';

const metadata = {
  title: 'UpgradR — Audit & Automatisation pour Entreprises',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Demander un diagnostic',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'Voir les services', href: '#services' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_55%_at_50%_0%,rgba(59,130,246,0.18),transparent)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_40%_35%_at_50%_0%,rgba(139,92,246,0.12),transparent)]"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image:radial-gradient(rgb(255 255 255) 1px,transparent 1px);background-size:28px 28px;"></div>
    </Fragment>

    <Fragment slot="title">
      Vos équipes perdent du temps sur des tâches qui pourraient
      <span class="bg-gradient-to-r from-blue-400 to-violet-400 bg-clip-text text-transparent"> se faire seules.</span>
    </Fragment>

    <Fragment slot="subtitle">
      UpgradR audite vos processus et automatise ce qui vous coûte du temps.
      <strong class="text-slate-200">Tarif fixe, sans surprise, sans recruter.</strong>
      Pour les PME et TPE francophones qui veulent scaler sans alourdir leur masse salariale.
    </Fragment>
  </Hero>

  <Note title="Diagnostic express :" description="On cartographie vos pertes de temps en 30 minutes — avant de vous proposer quoi que ce soit." />

  <Features
    id="services"
    tagline="Services"
    title="Ce qu'on fait pour vous"
    subtitle="On intervient là où vous perdez du temps et de l'argent sans le savoir."
    items={[
      {
        title: 'Audit processus',
        description: 'On cartographie vos flux de travail pour identifier les tâches manuelles inutiles, les goulots d\'étranglement et les outils mal exploités. C\'est notre service phare — et le point de départ de toute mission.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Automatisation sur mesure',
        description: 'Scripts, webhooks, no-code ou code — on automatise ce qui vous prend du temps : relances, reporting, synchronisation de données, facturation, etc.',
        icon: 'tabler:robot',
      },
      {
        title: 'Intégration IA',
        description: 'Chatbots internes, traitement de documents, génération de contenus, extraction de données — on intègre l\'IA là où elle crée de la valeur réelle.',
        icon: 'tabler:brain',
      },
      {
        title: 'Tableaux de bord & reporting',
        description: 'Vos données éparpillées dans 10 outils ? On centralise et automatise vos rapports pour piloter en temps réel, sans intervention manuelle.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Connexion d\'outils (CRM, ERP, etc.)',
        description: 'Zapier, Make, n8n, API custom — on connecte vos outils entre eux pour supprimer les saisies multiples et les erreurs humaines.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Formation & accompagnement',
        description: 'On ne disparaît pas après la livraison. On forme vos équipes et restons disponibles pour itérer — suivi 30 jours inclus dans chaque mission.',
        icon: 'tabler:users',
      },
    ]}
  />

  <Steps
    id="process"
    title="3 étapes pour automatiser votre entreprise"
    items={[
      {
        title: 'Étape 1 : <span class="font-medium">Diagnostic (30 min)</span>',
        description: 'On comprend votre activité, vos outils et vos points de douleur. On vous dit franchement ce qu\'on peut automatiser — et le ROI estimé.',
        icon: 'tabler:phone',
      },
      {
        title: 'Étape 2 : <span class="font-medium">Proposition sur mesure</span>',
        description: 'Un plan d\'action clair avec les automations prioritaires et un devis fixe. Vous savez ce que vous payez avant de signer.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Étape 3 : <span class="font-medium">Déploiement & formation</span>',
        description: 'On met en place, on teste, on forme vos équipes. Délai typique : 2 à 4 semaines.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Votre entreprise tourne seule.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=2070&q=80',
      alt: 'Process UpgradR',
    }}
  />

  <FAQs
    id="faq"
    title="Questions fréquentes"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'On est une petite structure, c\'est fait pour nous ?',
        description: 'Oui. On travaille avec des TPE et PME de 5 à 200 personnes, partout en francophonie. Les petites structures ont souvent plus à gagner — chaque heure perdue compte davantage.',
      },
      {
        title: 'Vous travaillez avec nos outils existants ?',
        description: 'Dans la grande majorité des cas, oui. On s\'adapte à votre stack (Google Workspace, Notion, Airtable, HubSpot, Salesforce, etc.) avant de recommander quoi que ce soit de nouveau.',
      },
      {
        title: 'Combien ça coûte ?',
        description: 'Nos audits démarrent à 500€. C\'est en dessous des grands audits financés BPI, mais nettement plus rapide et actionnable. Chaque mission se fait sur devis fixe — pas de facturation à l\'heure.',
      },
      {
        title: 'Combien de temps ça prend ?',
        description: 'Entre 2 et 4 semaines selon la complexité. Certaines automations simples sont livrées en moins d\'une semaine.',
      },
      {
        title: 'Et si ça ne fonctionne pas après la livraison ?',
        description: 'Suivi 30 jours post-déploiement inclus. Si une automation plante ou si le besoin évolue, on corrige sans facturation supplémentaire pendant cette période.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Demander mon diagnostic',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      1h de tâche manuelle par jour = 250h perdues par an.
    </Fragment>

    <Fragment slot="subtitle">
      On vous montre lesquelles automatiser — et ce que ça vous rapporte.<br/>
      Diagnostic express, résultats concrets.
    </Fragment>
  </CallToAction>

</Layout>
