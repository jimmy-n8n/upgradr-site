---
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'À propos — UpgradR',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="À propos"
    image={{
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=2070&q=80',
      alt: 'Équipe UpgradR',
    }}
  >
    <Fragment slot="title">
      On automatise ce qui vous<br />
      <span class="text-accent dark:text-white">coûte du temps et de l'argent.</span>
    </Fragment>

    <Fragment slot="subtitle">
      UpgradR est une agence spécialisée dans l'audit de processus et l'automatisation pour les PME et TPE françaises.
      On ne vend pas des outils — on livre des résultats concrets.
    </Fragment>
  </Hero>

  <Steps2
    title="Nos valeurs"
    items={[
      {
        title: 'Résultats avant tout',
        description: 'On ne facture pas des heures de consulting. On livre des automations qui tournent, des gains mesurables, des processus qui fonctionnent sans vous.',
      },
      {
        title: 'Transparence totale',
        description: 'Devis fixe, périmètre clair, pas de surprises. Vous savez ce que vous payez avant de signer.',
      },
      {
        title: 'Accompagnement réel',
        description: 'On forme vos équipes et on reste disponibles après la livraison. Le but : que vous soyez autonomes, pas dépendants de nous.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Réserver un audit gratuit',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">Prêt à gagner du temps ?</Fragment>
    <Fragment slot="subtitle">Un appel de 30 min suffit pour identifier vos premières pistes d'automatisation.</Fragment>
  </CallToAction>
</Layout>
