---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact — UpgradR',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Parlons de votre projet"
    subtitle="Décrivez-nous votre situation en quelques lignes. On vous répond sous 24h."
  />

  <ContactUs
    id="form"
    title="Demander un diagnostic"
    subtitle="30 minutes pour cartographier vos pertes de temps — avant qu'on vous propose quoi que ce soit."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nom',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email professionnel',
      },
    ]}
    textarea={{
      label: 'Décrivez votre activité et vos points de douleur',
    }}
    disclaimer={{
      label: 'En soumettant ce formulaire, vous acceptez que vos données soient utilisées pour vous recontacter.',
    }}
    description="Réponse garantie sous 24h ouvrées."
  />

  <Features2
    title="Autres façons de nous contacter"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'contact@upgradr.fr',
        icon: 'tabler:mail',
      },
      {
        title: 'Francophonie',
        description: 'Intervention 100% à distance. Disponibles aux horaires métropole (8h–18h Paris). Visio, Slack, email — on s\'adapte à vos outils.',
        icon: 'tabler:world',
      },
    ]}
  />
</Layout>
